# ===========================================
# ORO Round Environment Variables
# ===========================================
# Copy this file to .env.local for local development
# For Vercel deployment, add these in the Vercel Dashboard > Project Settings > Environment Variables

# -------------------------------------------
# Grail API Configuration (REQUIRED)
# -------------------------------------------
# Server-side API key for Grail API authentication
# Get this from Grail team - DO NOT expose client-side
GRAIL_API_KEY=your-grail-api-key-here

# Grail API URL (server-side)
# Devnet: https://oro-tradebook-devnet.up.railway.app
# Mainnet: https://oro-tradebook-mainnet.up.railway.app
GRAIL_API_URL=https://oro-tradebook-mainnet.up.railway.app

# -------------------------------------------
# Public Configuration (exposed to browser)
# -------------------------------------------
# Grail API URL for client-side (same as GRAIL_API_URL typically)
NEXT_PUBLIC_GRAIL_API_URL=https://oro-tradebook-mainnet.up.railway.app

# -------------------------------------------
# Solana Configuration (REQUIRED)
# -------------------------------------------
# Solana RPC endpoint
# IMPORTANT: For production, use a dedicated RPC provider (Helius, QuickNode, Alchemy, Triton)
# The free public endpoints have rate limits and may cause issues
# Devnet: https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com (or your provider URL)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana network: devnet | testnet | mainnet-beta
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# GOLD token mint address (SPL Token)
# Get the correct address for your network from Grail team
NEXT_PUBLIC_GOLD_MINT=

# -------------------------------------------
# Application Configuration
# -------------------------------------------
# Your production domain (used for OpenGraph, etc.)
NEXT_PUBLIC_APP_URL=https://ororound.vercel.app

# -------------------------------------------
# Sentry Configuration (OPTIONAL - for error tracking)
# -------------------------------------------
# Get these from sentry.io after creating a project
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# -------------------------------------------
# Analytics (OPTIONAL)
# -------------------------------------------
# Google Analytics Measurement ID
NEXT_PUBLIC_GA_ID=

# -------------------------------------------
# Feature Flags (OPTIONAL)
# -------------------------------------------
# Enable debug mode (shows extra logging)
NEXT_PUBLIC_DEBUG=false

# Put app in maintenance mode
NEXT_PUBLIC_MAINTENANCE_MODE=false
