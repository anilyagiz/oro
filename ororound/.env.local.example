# ===========================================
# ORO Round Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# -------------------------------------------
# Grail API Configuration
# -------------------------------------------
# The URL of the Grail API (required) — MAINNET
NEXT_PUBLIC_GRAIL_API_URL=https://oro-tradebook-mainnet.up.railway.app

# API key for Grail API authentication (server-side, never expose client-side)
GRAIL_API_KEY=your-grail-api-key-here

# Grail API URL used server-side (same as above)
GRAIL_API_URL=https://oro-tradebook-mainnet.up.railway.app

# -------------------------------------------
# Solana Configuration — MAINNET
# -------------------------------------------
# Use a dedicated RPC for production (NOT the free public endpoint — rate limits!)
# Recommended providers: Helius, QuickNode, Alchemy, Triton
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana network
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# Gold token mint address (SPL Token) — required for mainnet
NEXT_PUBLIC_GOLD_MINT=

# -------------------------------------------
# Application Configuration
# -------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-production-domain.vercel.app

# Google Analytics Measurement ID (optional)
NEXT_PUBLIC_GA_ID=

# -------------------------------------------
# Feature Flags (optional)
# -------------------------------------------
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_MAINTENANCE_MODE=false