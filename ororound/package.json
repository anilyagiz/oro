    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.0.0",
